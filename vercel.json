{
    "redirects": [
        {
            "source": "/scribe/app/:match*",
            "destination": "https://app.hanna.care/:match*",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/api/scribe/:path*",
            "destination": "https://hanna-line-bot-production.up.railway.app/api/scribe/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}